{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "numberOfRuns": 3,
      "url": [
        "http://localhost/index.html",
        "http://localhost/projets/index.html",
        "http://localhost/apropos/index.html",
        "http://localhost/contact/index.html",
        "http://localhost/mentions-legales/index.html",
        "http://localhost/projets/parcours-spvieassurances/index.html"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
